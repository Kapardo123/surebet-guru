{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/.well-known/assetlinks.json",
      "destination": "/.well-known/assetlinks.json"
    },
    {
      "source": "/test-json.json",
      "destination": "/test-json.json"
    },
    {
      "source": "/((?!.well-known|test-json).*)",
      "destination": "/index.html"
    }
  ]
}